    "cards": [
        {
            "infoCardId": "c001",
            "themeId": "base_default",
            "title": {
                "tr": "ANKARA",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Ankara, Cumhuriyet döneminde başkent olarak seçildi ve bugün Türkiye'nin yönetim merkezidir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c001"
        },
        {
            "infoCardId": "c005",
            "themeId": "base_default",
            "title": {
                "tr": "SU",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Su yaşam için temel unsurdur. Dünyanın büyük kısmı suyla kaplı olsa da içilebilir oran sınırlıdır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c005"
        },
        {
            "infoCardId": "c002",
            "themeId": "base_default",
            "title": {
                "tr": "KIRMIZI",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Türk bayrağındaki kırmızı, tarihsel olarak fedakarlık ve bağımsızlıkla ilişkilendirilir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c002"
        },
        {
            "infoCardId": "c010",
            "themeId": "base_default",
            "title": {
                "tr": "BAKLAVA",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Baklava, kat kat hamur ve şerbetle yapılan, Türk mutfağının en bilinen tatlılarından biridir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c010"
        },
        {
            "infoCardId": "c004",
            "themeId": "base_default",
            "title": {
                "tr": "JÜPİTER",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Jüpiter, Güneş Sistemi'ndeki en büyük gezegendir ve dev bir gaz gezegeni olarak sınıflandırılır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c004"
        },
        {
            "infoCardId": "c003",
            "themeId": "base_default",
            "title": {
                "tr": "İSTANBUL",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "İstanbul, iki kıtaya yayılan yapısı ve tarihi geçmişiyle dünyanın en özel şehirlerinden biridir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c003"
        },
        {
            "infoCardId": "c009",
            "themeId": "base_default",
            "title": {
                "tr": "NİL",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Nil, Afrika'nın en ünlü nehirlerinden biridir ve çok sayıda ülkenin içinden geçer.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c009"
        },
        {
            "infoCardId": "c007",
            "themeId": "base_default",
            "title": {
                "tr": "ATATÜRK",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Mustafa Kemal Atatürk, Türkiye Cumhuriyeti'nin kurucusu ve ilk cumhurbaşkanıdır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c007"
        },
        {
            "infoCardId": "c006",
            "themeId": "base_default",
            "title": {
                "tr": "İZMİR",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Efes antik kenti İzmir sınırları içindedir ve Roma döneminin en önemli merkezlerinden biridir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c006"
        },
        {
            "infoCardId": "c017",
            "themeId": "base_default",
            "title": {
                "tr": "AĞRI",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Ağrı Dağı, Türkiye'nin en yüksek dağıdır ve efsanelerle sık sık anılır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c017"
        },
        {
            "infoCardId": "c014",
            "themeId": "base_default",
            "title": {
                "tr": "OSMAN",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Osman Bey, Osmanlı Beyliği'nin kurucusu olarak kabul edilir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c014"
        },
        {
            "infoCardId": "c012",
            "themeId": "base_default",
            "title": {
                "tr": "FINDIK",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Türkiye, dünya fındık üretiminde uzun yıllardır lider ülkelerden biridir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c012"
        },
        {
            "infoCardId": "c011",
            "themeId": "base_default",
            "title": {
                "tr": "TROYA",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Troya, Truva Savaşı ile tanınan antik kenttir ve arkeoloji tarihinde önemli bir yere sahiptir.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c011"
        },
        {
            "infoCardId": "c019",
            "themeId": "base_default",
            "title": {
                "tr": "İZMİR",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Türkiye'deki ilk demiryolu hattı İzmir merkezli olarak gelişti.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c019"
        },
        {
            "infoCardId": "c008",
            "themeId": "base_default",
            "title": {
                "tr": "NEVŞEHİR",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Kapadokya'nın peri bacaları ve yer altı şehirleri Nevşehir çevresinde yoğunlaşır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c008"
        },
        {
            "infoCardId": "c018",
            "themeId": "base_default",
            "title": {
                "tr": "WATSON",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Watson, Crick ile birlikte DNA'nın çift sarmal yapısının açıklanmasında rol oynadı.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c018"
        },
        {
            "infoCardId": "c015",
            "themeId": "base_default",
            "title": {
                "tr": "BOĞAZİÇİ",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Boğaziçi, Asya ile Avrupa'yı ayıran ve İstanbul'un simgesi haline gelen su yoludur.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c015"
        },
        {
            "infoCardId": "c013",
            "themeId": "base_default",
            "title": {
                "tr": "ÜÇ YÜZ BİN",
                "en": "",
                "es": "",
                "de": ""
            },
            "body": {
                "tr": "Işık, boşlukta saniyede yaklaşık üç yüz bin kilometre yol alır.",
                "en": "",
                "es": "",
                "de": ""
            },
            "imageResourcePath": "Cards/Base/c013"
        },
        {
